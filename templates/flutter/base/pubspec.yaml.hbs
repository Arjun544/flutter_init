name: {{flags.appSlug}}
description: {{description}}
publish_to: "none"
version: 1.0.0+1

environment:
sdk: ">=3.5.0 <4.0.0" dependencies: flutter: sdk: flutter cupertino_icons: ^1.0.8 {{#if flags.routerPackage}}
    {{flags.routerPackage}}: ^14.2.1 {{/if}} {{#if flags.usesDio}} dio: ^5.7.0 {{/if}} {{#if flags.usesHttp}} http:
    ^1.2.2 {{/if}} {{#if flags.isRiverpod}} flutter_riverpod: ^2.5.1 {{/if}} {{#if flags.isProvider}} provider: ^6.1.2
    {{/if}} {{#if flags.isBloc}} flutter_bloc: ^9.0.0 {{/if}} {{#if flags.isGetX}} get: ^4.6.6 {{/if}} {{#if
    flags.isMobX}} mobx: ^2.3.3 flutter_mobx: ^2.2.0 {{/if}} {{#if flags.usesGoogleFont}} google_fonts: ^6.2.1 {{/if}}
    {{#if (eq backend.provider "firebase" )}} firebase_core: ^3.9.0 {{#if backend.options.authEmail}}firebase_auth:
    ^5.3.1{{/if}} {{#if backend.options.firestore}}cloud_firestore: ^5.5.1{{/if}} {{#if
    backend.options.realtimeDb}}firebase_database: ^11.1.4{{/if}} {{#if backend.options.storage}}firebase_storage:
    ^12.3.4{{/if}} {{#if backend.options.analytics}}firebase_analytics: ^11.3.4{{/if}} {{#if
    backend.options.crashlytics}}firebase_crashlytics: ^4.1.4{{/if}} {{/if}} {{#if (eq backend.provider "supabase" )}}
    supabase_flutter: ^2.8.0 {{/if}} {{#if (eq backend.provider "appwrite" )}} appwrite: ^12.0.2 {{/if}} {{#if
    flags.usesHive}} hive: ^2.2.3 hive_flutter: ^1.1.0 {{/if}} {{#if flags.usesSharedPreferences}} shared_preferences:
    ^2.3.4 {{/if}} {{#if flags.usesDotenv}} flutter_dotenv: ^5.1.0 {{/if}} {{#if flags.usesLogger}} logger: ^2.5.0
    {{/if}} {{#if flags.supportsLocalization}} flutter_localizations: sdk: flutter {{/if}} dev_dependencies:
    flutter_test: sdk: flutter flutter_lints: ^4.0.0 {{#if (or flags.isMobX (eq
    flags.routerPackage "auto_route" ))}} build_runner: ^2.4.12 {{/if}} {{#if flags.isMobX}}
    mobx_codegen: ^2.6.2 {{/if}} {{#if (eq flags.routerPackage "auto_route" )}} auto_route_generator: ^9.2.2 {{/if}}
    flutter: uses-material-design: true assets: - assets/ {{#if theme.font.family}} fonts: - family:
    {{theme.font.family}} fonts: - asset: assets/fonts/{{snakeCase theme.font.family}}.ttf {{/if}}