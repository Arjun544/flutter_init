import 'package:{{flags.appSnake}}/src/utils/utils.dart';
import 'package:{{flags.appSnake}}/src/{{#if (eq architecture "layer-first")}}domain/auth/models/{{else if (eq architecture "mvc")}}models/auth/{{else if (eq architecture "mvvm")}}models/auth/{{else}}features/auth/domain/models/{{/if}}user_model.dart';

abstract class AuthRepository {
  /// Sign in with email and password
  FutureEither<AppUser> login({
    required String email,
    required String password,
  });

  /// Sign up with email, password, and optional name
  FutureEither<AppUser> signUp({
    required String name,
    required String email,
    required String password,
  });

  /// Send a password reset email
  FutureEither<void> forgotPassword({
    required String email,
  });

  /// Sign out the current user
  FutureEither<void> logout();
  
  /// Check if the user is currently authenticated natively
  FutureEither<AppUser?> checkAuthState();
}
